---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  class:list={["icon", className]}
>
  <circle cx="12" cy="12" r="10"></circle>
  <path
    d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
  ></path>
</svg>

<style>
  .icon {
    width: 1em;
    height: 1em;
  }
</style>
